# ═══════════════════════════════════════════════════════════════════════════
# Gina's Tennis World — Backend Environment Variables
# Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="Gina's Tennis World API"
ENVIRONMENT=development   # development | staging | production

# ── Database ─────────────────────────────────────────────────────────────────
# For local SQLite (default, no DB server needed):
DB_ENGINE=sqlite

# For PostgreSQL (production):
# DB_ENGINE=postgresql
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=ginas_tennis
# DB_USER=postgres
# DB_PASSWORD=your_secure_password_here

# Or set DATABASE_URL directly (overrides all DB_* vars above):
# DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require

# ── Authentication ────────────────────────────────────────────────────────────
# IMPORTANT: Change this to a long random string in production!
JWT_SECRET=change-me-to-a-secure-random-string-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
# For production:
# ALLOWED_ORIGINS=["https://ginastennisworld.com","https://www.ginastennisworld.com"]

# ── Frontend URL ─────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Stripe (Payments) ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_CURRENCY=usd

# ── Payment Methods ─────────────────────────────────────────────────────────
# Toggle which payment methods Gina accepts (true/false)
CASH_ENABLED=true
CHECK_ENABLED=true
VENMO_ENABLED=true
ZELLE_ENABLED=true
PAY_AT_LOCATION_ENABLED=true

# Display info shown to customers during checkout
VENMO_HANDLE=@Gina-Tennis
ZELLE_INFO=ginas@tennis.com

# ── Email (Transactional) ───────────────────────────────────────────────────
EMAIL_PROVIDER=console
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
EMAIL_FROM_ADDRESS=noreply@ginastennisworld.com
EMAIL_FROM_NAME="Gina's Tennis World"
EMAIL_BASE_URL=http://localhost:3000