# ═══════════════════════════════════════════════════════════════════════════
# Gina's Tennis World — Frontend Environment Variables
# Copy this file to .env.local and fill in your values.
# ═══════════════════════════════════════════════════════════════════════════

# ── Backend URL ──────────────────────────────────────────────────────────────
# Used by the Next.js API proxy route to forward requests to FastAPI
BACKEND_URL=http://localhost:8000

# ── Stripe (client-side) ─────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# ── WebSocket ────────────────────────────────────────────────────────────────
# Leave empty to auto-detect from current page protocol/host
# NEXT_PUBLIC_WS_URL=ws://localhost:8000